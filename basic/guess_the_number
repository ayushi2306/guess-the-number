import random
number = random.randint(0, 1000)
print("Guess the number between 0 and 1000")
while True:
    guess = int(input("Enter your guess: "))

    if guess < number:
        print("Higher!")

    elif guess > number:
        print("Lower!")

    else:
        print("Congratulations! You guessed the correct number.")
        break
